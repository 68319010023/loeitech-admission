# Environment Variables
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Supabase Configuration (Mock for development)
SUPABASE_URL=https://mock.supabase.co
SUPABASE_ANON_KEY=mock_anon_key_for_development
SUPABASE_SERVICE_ROLE_KEY=mock_service_role_key_for_development

# JWT Secret
JWT_SECRET=mock_jwt_secret_for_development_only

# Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,application/pdf

# OCR Configuration
OCR_TIMEOUT=30000
